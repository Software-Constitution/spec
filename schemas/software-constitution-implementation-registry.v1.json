{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://softwareconstitution.com/schemas/implementation-registry.v1.json",
  "title": "software-constitution.implementation_registry.v1",
  "description": "Language-agnostic schema for the Implementation Registry. Conforming projects MUST validate their implementation/registry.json against this schema. See SPEC.md §6.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "version", "concepts"],
  "properties": {
    "schema": { "const": "software-constitution.implementation_registry.v1" },
    "version": { "type": "string" },
    "adopted": { "type": "string", "format": "date" },
    "constitution_ref": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["concept_id", "name", "ssot_module"],
        "properties": {
          "concept_id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
          "name": { "type": "string", "minLength": 3 },
          "plane": { "type": "string" },
          "constitution_ref": { "type": "string" },
          "ssot_module": { "type": "string", "minLength": 1 },
          "ssot_package": { "type": ["string", "null"] },
          "ssot_entry_point": { "type": ["string", "null"] },
          "transport_wrappers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["module", "transport"],
              "properties": {
                "module": { "type": "string" },
                "transport": { "type": "string" },
                "must_import": { "type": "string" }
              }
            }
          },
          "competitor_forbidden_patterns": { "type": "array", "items": { "type": "string" } },
          "migration": {
            "type": "object",
            "additionalProperties": true,
            "required": ["status"],
            "properties": {
              "status": { "type": "string", "enum": ["pending", "in-progress", "complete"] },
              "advisory_until": { "type": "string", "format": "date" },
              "tracked_in": { "type": "string" },
              "wrappers_pending_import": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
